@page "/"
@using CorporateEnergyAPI.Interfaces
@using CorporateEnergyAPI.Models
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@implements IDisposable
@inject IEnergyService EnergyService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<div class="container-fluid py-4" style="background-color: #050505; min-height: 100vh; color: #ffffff;">

    @if (IsAnomalous)
    {
        <div class="alert shadow-lg mb-4"
             style="background-color: #721c24; border: 1px solid #f5c6cb; border-radius: 10px; animation: pulse-red 2s infinite;">
            <div class="d-flex align-items-center text-white">
                <span style="font-size: 1.5rem; margin-right: 10px;">⚠️</span>
                <div>
                    <strong>ANOMALIE GEDETECTEERD:</strong> De huidige prijs van € @CurrentPrice.ToString("N2") wijkt
                    extreem af!
                </div>
            </div>
        </div>
    }

    <div class="alert shadow-lg mb-4"
         style="background-color: #121212; border-left: 5px solid #66fcf1; border-radius: 10px;">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <span class="badge bg-danger mb-2" style="animation: blinker 1.5s linear infinite;">LIVE
                    SIMULATIE</span>
                    <h3 style="color: #66fcf1; font-weight: 800; margin-bottom: 0;">@CurrentSimulatedMonthYear</h3>
                </div>
                <div class="text-end">
                    <p style="color: #45a29e; font-size: 0.8rem; margin-bottom: 0;">Systeem Tijdstempel:</p>
                    <h5 style="color: #ffffff; font-weight: 600;">@CurrentFormattedTimestamp</h5>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-4 mb-3">
                <div class="card border-0 shadow h-100"
                     style="background-color: #121212; border-left: 5px solid #66fcf1 !important;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h6 style="color: #66fcf1; text-transform: uppercase; font-size: 0.7rem; font-weight: 600;">
                                    Actuele Prijs</h6>
                                    <h2 style="color: #ffffff; font-weight: 800; font-size: 2rem; margin-bottom: 5px;">€
                                        @CurrentPrice.ToString("N2")</h2>
                                        <small style="color: #45a29e;">per MWh</small>
                                    </div>
                                    <div style="font-size: 2.5rem; opacity: 0.3;">⚡</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <div class="card border-0 shadow h-100"
                             style="background-color: #121212; border-left: 5px solid #ff6b6b !important;">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 style="color: #ff6b6b; text-transform: uppercase; font-size: 0.7rem; font-weight: 600;">
                                            Hoogste Prijs</h6>
                                            <h2 style="color: #ff6b6b; font-weight: 800; font-size: 2rem; margin-bottom: 5px;">€
                                                @HighestPrice.ToString("N2")</h2>
                                                <small style="color: #888;">Piekbelasting</small>
                                            </div>
                                            <div style="font-size: 2.5rem; opacity: 0.3;">📈</div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-4 mb-3">
                                <div class="card border-0 shadow h-100"
                                     style="background-color: #121212; border-left: 5px solid @(PriceChange >= 0 ? "#00ff88" : "#ff6b6b") !important;">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h6
                                                    style="color: @(PriceChange >= 0 ? "#00ff88" : "#ff6b6b"); text-transform: uppercase; font-size: 0.7rem; font-weight: 600;">
                                                    Verandering</h6>
                                                    <h2
                                                        style="color: @(PriceChange >= 0 ? "#00ff88" : "#ff6b6b"); font-weight: 800; font-size: 2rem; margin-bottom: 5px;">
                                                        @(PriceChange >= 0 ? "+" : "")@PriceChange.ToString("F1")%
                                                    </h2>
                                                    <small style="color: #888;">vs vorige periode</small>
                                                </div>
                                                <div style="font-size: 2.5rem; opacity: 0.3;">@(PriceChange >= 0 ? "📈" : "📉")</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row align-items-stretch">
                                <div class="col-lg-9 col-md-8 d-flex flex-column">
                                    <div class="card border-0 shadow mb-4" style="background-color: #121212; height: 350px; overflow: hidden;">
                                        <div class="card-body p-3" style="height: 100%;">
                                            <h5 style="color: #66fcf1; font-size: 1rem; margin-bottom: 10px;">Markttrend & AI Voorspelling</h5>
                                            <div style="height: calc(100% - 40px); width: 100%; position: relative;">
                                                <canvas id="energyChart"></canvas>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="card border-0 shadow flex-grow-1"
                                         style="background-color: #121212; border-top: 3px solid #00ff88;">
                                        <div class="card-body d-flex align-items-center">
                                            <div class="row w-100 justify-content-center align-items-center">
                                                <div class="col-md-3 text-center border-end border-secondary">
                                                    <h6 style="color: #45a29e; text-transform: uppercase; font-size: 0.7rem;">Correlatie</h6>
                                                    <h2 style="color: #00ff88; font-weight: 800;">@CorrelationScore.ToString("F2")</h2>
                                                    <small style="color: #888;">Duurzaam vs Prijs</small>
                                                </div>

                                                <div class="col-md-5 px-5 border-end border-secondary">
                                                    <h6 style="color: #66fcf1; font-size: 0.85rem; text-align: center;" class="mb-3">Wat-Als
                                                        Simulator:</h6>
                                                        <div class="px-2">
                                                            <label class="small text-muted d-flex justify-content-between mb-2">
                                                                <span>Extra Duurzame Energie:</span>
                                                                <span style="color: #00ff88; font-weight: bold;">+@ExtraGreenEnergy%</span>
                                                            </label>
                                                            <input type="range" class="form-range custom-green-slider" min="0" max="100" step="5"
                                                                   @bind="ExtraGreenEnergy" @bind:event="oninput" @onchange="CalculateScenario" />
                                                            <p class="mt-2 mb-0 text-center" style="font-size: 0.65rem; color: #45a29e;">
                                                                * Pas de groene mix aan om de prijsimpact te berekenen.
                                                            </p>
                                                        </div>
                                                    </div>

                                                    <div class="col-md-4 text-center">
                                                        <h6 style="color: #ffcc00; font-size: 0.85rem;">Verwachte Prijsimpact:</h6>
                                                        <h4 style="color: #ffffff; font-weight: 700; margin-bottom: 5px;">
                                                            € @SimulatedPrice.ToString("N2")
                                                        </h4>
                                                        <div class="progress mx-auto" style="height: 6px; background-color: #1a1a1a; width: 80%;">
                                                            <div class="progress-bar bg-warning"
                                                                 style="width: @(Math.Min(100, (SimulatedPrice / HighestPrice) * 100))%"></div>
                                                        </div>
                                                        <small class="d-block mt-2" style="color: #00ff88; font-size: 0.75rem; font-weight: 600;">
                                                            Besparing: @((CurrentPrice - SimulatedPrice).ToString("N2")) €/MWh
                                                        </small>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-lg-3 col-md-4">
                                        <div class="d-flex flex-column h-100">
                                            <div class="card border-0 shadow mb-4"
                                                 style="background-color: #121212; border-top: 3px solid @VolatilityColor; transition: 0.5s;">
                                                <div class="card-body text-center">
                                                    <h6 style="color: #45a29e; text-transform: uppercase; font-size: 0.7rem; font-weight: 700;">
                                                        Markt Volatiliteit</h6>
                                                        <h3 class="mt-2" style="color: @VolatilityColor; font-weight: 800; margin: 0;">σ
                                                            @VolatilityScore.ToString("F2")</h3>
                                                            <span class="badge mt-2"
                                                                  style="background-color: @(VolatilityColor + "33"); color: @VolatilityColor; border: 1px solid @VolatilityColor;">
                                                                @VolatilityStatus
                                                            </span>
                                                        </div>
                                                    </div>

                                                    <div class="card border-0 shadow flex-grow-1" style="background-color: #121212; border-radius: 15px;">
                                                        <div class="card-header border-0 bg-transparent pt-4">
                                                            <h6 style="color: #66fcf1; font-weight: 800; font-size: 0.85rem;">🤖 AI BENCHMARK</h6>
                                                            <hr style="background-color: #333;" />
                                                        </div>
                                                        <div class="card-body pt-0 d-flex flex-column">
                                                            <div class="flex-grow-1">
                                                                @foreach (var model in AIModels)
                                                                {
                                                                    <div class="mb-3 p-2 rounded" style="background-color: #0a0a0a;">
                                                                        <div class="d-flex justify-content-between mb-1">
                                                                            <small style="color: #ffffff; font-weight: 600;">@model.Name</small>
                                                                            <small
                                                                            style="color: @GetAccuracyColor(model.Accuracy);">@model.Accuracy.ToString("F1")%</small>
                                                                        </div>
                                                                        <div class="d-flex justify-content-between mb-2">
                                                                            <small style="color: #45a29e;">Voorspelling:</small>
                                                                            <span style="font-weight: bold; color: #ffffff;">€
                                                                                @model.PredictedPrice.ToString("N2")</span>
                                                                            </div>
                                                                            <div class="progress" style="height: 4px; background-color: #1a1a1a;">
                                                                                <div class="progress-bar"
                                                                                     style="width: @model.Accuracy%; background-color: @GetAccuracyColor(model.Accuracy);">
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    }
                                                                </div>

                                                                <div class="mt-auto pt-3">
                                                                    <div class="p-3 rounded text-center"
                                                                         style="background-color: #0a0a0a; border: 1px solid #1a1a1a;">
                                                                        <small style="color: #45a29e; font-size: 0.7rem;">GEZAMENLIJKE VOORSPELLING</small>
                                                                        <h4 style="color: #ffffff; font-weight: 800; margin-bottom: 0;">€ @AIModels.Average(m =>
                                                                                                                m.PredictedPrice).ToString("N2")</h4>
                                                                        </div>
                                                                        <button class="btn btn-outline-info btn-sm w-100 mt-3" @onclick="ExportData">📥 Export
                                                                            CSV</button>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <style>
                                                    @@keyframes pulse-red {
                                                        0% {
                                                            box-shadow: 0 0 0 0 rgba(255, 77, 77, 0.4);
                                                        }

                                                        70% {
                                                            box-shadow: 0 0 0 10px rgba(255, 77, 77, 0);
                                                        }

                                                        100% {
                                                            box-shadow: 0 0 0 0 rgba(255, 77, 77, 0);
                                                        }
                                                    }

                                                    @@keyframes blinker {
                                                        50% {
                                                            opacity: 0.2;
                                                        }
                                                    }

                                                    /* Custom Groene Slider Styling */
                                                    .custom-green-slider::-webkit-slider-runnable-track {
                                                        background: #1a1a1a;
                                                        height: 8px;
                                                        border-radius: 4px;
                                                        border: 1px solid #333;
                                                    }

                                                    .custom-green-slider::-webkit-slider-thumb {
                                                        background: #00ff88 !important;
                                                        box-shadow: 0 0 10px rgba(0, 255, 136, 0.5);
                                                        border: none;
                                                        height: 18px;
                                                        width: 18px;
                                                        margin-top: -6px;
                                                    }

                                                    .custom-green-slider::-moz-range-track {
                                                        background: #1a1a1a;
                                                        height: 8px;
                                                        border-radius: 4px;
                                                    }

                                                    .custom-green-slider::-moz-range-thumb {
                                                        background: #00ff88 !important;
                                                        border: none;
                                                    }
                                                </style>

@code {
    private EnergyDashboardViewModel? DashboardData;
    private System.Threading.Timer? _simulationTimer;
    private int _currentOffset = 0;

    private double CurrentPrice = 0;
    private double PreviousPrice = 0;
    private double HighestPrice = 0;
    private double PriceChange = 0;
    private bool IsAnomalous = false;
    private double CorrelationScore = -0.74;

    private double VolatilityScore = 0;
    private string VolatilityStatus = "Stabiel";
    private string VolatilityColor = "#00ff88";

    // Wat-Als Analyse Variabelen
    private int ExtraGreenEnergy = 0;
    private double SimulatedPrice = 0;

    public class AIModelInfo
    {
        public string Name { get; set; } = "";
        public double PredictedPrice { get; set; }
        public double PreviousPrediction { get; set; }
        public double Accuracy { get; set; }
        public bool IsDetectingAnomaly { get; set; }
    }

    private List<AIModelInfo> AIModels = new() {
        new AIModelInfo { Name = "XGBoost", Accuracy = 90.9, PredictedPrice = 57.61 },
        new AIModelInfo { Name = "LSTM RNN", Accuracy = 89.1, PredictedPrice = 59.14 },
        new AIModelInfo { Name = "Random Forest", Accuracy = 90.0, PredictedPrice = 58.66 },
        new AIModelInfo { Name = "Lineaire Baseline", Accuracy = 88.0, PredictedPrice = 58.59 }
    };

    private string CurrentSimulatedMonthYear = "Laden...";
    private string CurrentFormattedTimestamp = "";
    private bool _isJsReady = false;

    protected override async Task OnInitializedAsync() => await LoadData();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isJsReady = true;
            await RefreshChart();
            _simulationTimer = new System.Threading.Timer(async _ =>
            {
                await InvokeAsync(async () =>
                {
                    _currentOffset++;
                    await LoadData();
                    if (_isJsReady) await RefreshChart();
                    StateHasChanged();
                });
            }, null, 3000, 3000);
        }
    }

    private async Task LoadData()
    {
        DashboardData = await EnergyService.GetSimulationStepAsync(_currentOffset);
        if (DashboardData?.LatestEnergyPrices != null && DashboardData.LatestEnergyPrices.Any())
        {
            var latest = DashboardData.LatestEnergyPrices.First();
            PreviousPrice = CurrentPrice > 0 ? CurrentPrice : latest.Price_MWh;
            CurrentPrice = latest.Price_MWh;
            HighestPrice = Math.Max(HighestPrice, DashboardData.LatestEnergyPrices.Max(x => x.Price_MWh));
            PriceChange = PreviousPrice > 0 ? ((CurrentPrice - PreviousPrice) / PreviousPrice) * 100 : 0;

            var prices = DashboardData.LatestEnergyPrices.Select(x => x.Price_MWh).ToList();
            double avg = prices.Average();
            double sumOfSquares = prices.Sum(p => Math.Pow(p - avg, 2));
            VolatilityScore = Math.Sqrt(sumOfSquares / prices.Count);

            if (VolatilityScore > 10) { VolatilityStatus = "Volatiel"; VolatilityColor = "#ff6b6b"; }
            else if (VolatilityScore > 5) { VolatilityStatus = "Onrustig"; VolatilityColor = "#ffcc00"; }
            else { VolatilityStatus = "Stabiel"; VolatilityColor = "#00ff88"; }

            IsAnomalous = Math.Abs(CurrentPrice - avg) > (avg * 0.5);

            var greenRatio = (double)DashboardData.LatestEnergyPrices.Count(x => x.Is_Green_Energy == 1) /
DashboardData.LatestEnergyPrices.Count;
            CorrelationScore = -0.6 - (greenRatio * 0.3);

            CalculateScenario();
            var predictions = await EnergyService.GetLatestPredictionsAsync();
            if (predictions != null && predictions.Any())
            {
                AIModels = predictions.Select(p => new AIModelInfo
                {
                    Name = p.ModelName,
                    PredictedPrice = p.PredictedPrice,
                    Accuracy = Math.Max(80, 100 - Math.Abs(p.PredictedPrice - p.ActualPrice) / p.ActualPrice * 100)
                }).ToList();
            }
            UpdateAIModels(CurrentPrice);

            CurrentSimulatedMonthYear = latest.Timestamp.ToString("MMMM yyyy", new
System.Globalization.CultureInfo("nl-NL")).ToUpper();
            CurrentFormattedTimestamp = latest.Timestamp.ToString("dd/MM/yyyy HH:mm");
        }
    }

    private void CalculateScenario()
    {
        // Elke 1% extra groen verlaagt de prijs met 0.4%
        SimulatedPrice = CurrentPrice * (1 - (ExtraGreenEnergy * 0.004));
    }

    private void UpdateAIModels(double actualPrice)
    {
        var rnd = new Random();
        foreach (var model in AIModels)
        {
            if (model.PreviousPrediction > 0)
            {
                double error = Math.Abs(actualPrice - model.PreviousPrediction) / actualPrice;
                model.Accuracy = Math.Max(80, (model.Accuracy * 0.9) + ((1 - error) * 100 * 0.1));
            }
            model.PreviousPrediction = model.PredictedPrice;
            model.PredictedPrice = actualPrice * (1 + (rnd.NextDouble() * 0.1 - 0.05));
            model.IsDetectingAnomaly = IsAnomalous && model.Accuracy > 90;
        }
    }

    private string GetAccuracyColor(double acc) => acc > 95 ? "#00ff88" : acc > 90 ? "#66fcf1" : "#ffcc00";

    private async Task RefreshChart()
    {
        if (DashboardData?.LatestEnergyPrices == null || !_isJsReady) return;
        try
        {
            var sorted = DashboardData.LatestEnergyPrices.OrderBy(x => x.Timestamp).ToList();
            await JSRuntime.InvokeVoidAsync("setupLineChart", "energyChart",
                sorted.Select(x => x.Timestamp.ToString("HH:mm")).ToArray(),
                sorted.Select(x => x.Price_MWh).ToArray());
        }
        catch { }
    }

    private async Task ExportData()
    {
        if (DashboardData?.LatestEnergyPrices == null) return;
        await JSRuntime.InvokeVoidAsync("downloadCsvFromBlazor", "EnergyData_Export.csv", DashboardData.LatestEnergyPrices);
    }

    public void Dispose() => _simulationTimer?.Dispose();
}